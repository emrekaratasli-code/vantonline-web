# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your_project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Canonical production site URL
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# Legacy alias kept for backward compatibility
NEXT_PUBLIC_BASE_URL=https://yourdomain.com

# Meta (Facebook) Pixel ID - fires only in production
NEXT_PUBLIC_META_PIXEL_ID=

# Legacy alias kept for backward compatibility
NEXT_PUBLIC_FB_PIXEL_ID=

# Google Analytics Measurement ID (optional)
NEXT_PUBLIC_GA_ID=

# Hero Video Fallback URL
NEXT_PUBLIC_HERO_VIDEO_FALLBACK_URL=/videos/hero.mp4

# J.A.R.V.I.S. chatbot backend (Render API base URL)
# Example: https://jarvis-bot-2d6x.onrender.com
CHATBOT_API_URL=

# iyzico
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://api.iyzipay.com

# Email notifications
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
CONTACT_NOTIFICATION_TO=you@yourdomain.com

# API auth
API_SECRET_KEY=
JARVIS_REQUIRE_APPROVAL=true
JARVIS_OWNER_APPROVAL_KEY=

# OTP debug bypass (do not enable in production)
OTP_DEV_BYPASS=false
OTP_DEV_CODE=123456
